{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/:path(.+\\.entry\\.js)$",
      "destination": "/vertex-viewer-esm/:path"
    },
    {
      "source": "/:path(.+\\.entry\\.js\\.map)$",
      "destination": "/vertex-viewer-esm/:path"
    }
  ]
}